APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Production: full canonical origin with no path suffix when using web-root deployment (see ai/LARAVEL_LIVEWIRE_CONVERSION_PLAN.md §10.1).
APP_URL=http://localhost

# Legacy includes/session.php default (Africa/Accra)
APP_TIMEZONE=Africa/Accra

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=new_college
DB_USERNAME=root
DB_PASSWORD=

# file = no DB sessions table (see ai/ADR_DATABASE_INFRASTRUCTURE.md)
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# database = jobs table + queue:work worker (see ai/ADR_DATABASE_INFRASTRUCTURE.md)
QUEUE_CONNECTION=database

# file = no cache DB tables (see ai/ADR_DATABASE_INFRASTRUCTURE.md)
CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# First-time admin signup when no school row exists (legacy default: system_secret)
# SYSTEM_REGISTRATION_SECRET=system_secret

# No SYSTEM_PASSWORD — use admin impersonation when implemented (see ai/ADR_DATABASE_INFRASTRUCTURE.md).

# Delete all users when no school exists (bootstrap middleware); set false to skip
# COLLEGE_BOOTSTRAP_PURGE_USERS=true

# Allow GET /env-generator in local only (legacy generate_env — keep false in production)
# COLLEGE_ALLOW_WEB_ENV_GENERATOR=false

# Passport-style profile photo GD checks (legacy image_validation.php). Tests set false in phpunit.xml.
# COLLEGE_PASSPORT_VALIDATION_ENABLED=true

# Licence tier enforcement (false = all features allowed; legacy LICENCE_ENFORCE)
# LICENCE_ENFORCE=true

# Student cap when max_active_students is set: block | warn (legacy STUDENT_CAP_MODE)
# STUDENT_CAP_MODE=block

# Cached school_licences row TTL in seconds
# LICENCE_CACHE_TTL=300

# Legacy maintenance flag: when true, web requests redirect to GET /shutdown (see config/college.php).
# For framework maintenance prefer: php artisan down
# SERVER_DOWN=false

# Software Demo Mode: when true, forces the application to run in SQLite sandbox mode with pre-seeded data
# APP_DEMO=false

# true  = show landing page at /
# false = redirect / to /login (default for school installations)
LANDING_PAGE_ENABLED=false


# MySQL backup CLI (optional; defaults to mysqldump/mysql on PATH). See docs/BACKUP_INTEGRATION.md
# MYSQLDUMP_PATH=
# MYSQL_PATH=

# -----------------------------------------------------------------------------
# Cutover from legacy (includes/load_env.php): map remaining keys into config/*.php
# when switching DNS to new-college/public. Prefer Laravel env names above; document
# any legacy-only variables in ai/CONVERSION_LOG.md during migration.
# -----------------------------------------------------------------------------
