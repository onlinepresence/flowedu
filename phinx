#!/usr/bin/env php
<?php

// Ensure required directories exist
$requiredDirs = ['db/migrations', 'db/seeds'];
foreach ($requiredDirs as $dir) {
    if (!is_dir($dir)) {
        mkdir($dir, 0777, true);
        echo "Created: $dir\n";
    }
}

require __DIR__ . '/vendor/autoload.php';

$app = new Phinx\Console\PhinxApplication();
$app->run();
